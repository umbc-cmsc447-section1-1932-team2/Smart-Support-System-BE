generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  AGENT
  ADMIN
}

model Company {
  id    String @id @default(uuid())
  name  String
  users User[] 
}

model User {
  id         String   @id @default(uuid())
  username   String?
  email      String   @unique
  password   String
  phone      String?  @unique
  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id])
  role       Role     @default(USER)
}

